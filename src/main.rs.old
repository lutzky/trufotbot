use teloxide::prelude::*;
use teloxide::types::{BotCommand, InlineKeyboardButton, InlineKeyboardMarkup, WebAppInfo};
use teloxide::utils::command::BotCommands;
use url::Url;

#[derive(BotCommands, Clone)]
#[command(rename_rule = "lowercase")]
enum Command {
    /// Show this message.
    Help,
    /// Test a message with a keyboard
    KeyboardTest,
    /// Show how messages can be edited
    EditTest,
    /// Echo something back to me
    Echo(String),
}

#[tokio::main]
async fn main() {
    pretty_env_logger::init();
    log::info!("Starting bot");

    let bot = Bot::from_env();

    bot.set_chat_menu_button()
        .menu_button(teloxide::types::MenuButton::Default)
        .send()
        .await
        .unwrap();

    Command::repl(bot, answer).await;
}

fn make_keyboard() -> InlineKeyboardMarkup {
    let buttons = vec![vec![InlineKeyboardButton::callback(
        "some_text",
        "some_callback_data",
    )]];
    InlineKeyboardMarkup::new(buttons)
}

async fn answer(bot: Bot, msg: Message, cmd: Command) -> ResponseResult<()> {
    match cmd {
        Command::Help => {
            log::info!("Setting chat menu button for chat_id {}", msg.chat.id);
            bot.set_chat_menu_button()
                .menu_button(teloxide::types::MenuButton::WebApp {
                    text: "Web App".to_string(),
                    web_app: WebAppInfo {
                        url: Url::parse("https://example.com").unwrap(),
                    },
                })
                .send()
                .await
                .unwrap();
            log::info!(
                "Chat menu button: {:?}",
                bot.get_chat_menu_button().send().await
            );
            bot.set_my_commands(vec![
                BotCommand::new("custom_command1", "Description 1"),
                BotCommand::new("custom_command2", "Description 2"),
                BotCommand::new("custom_command3", "Description 3"),
                BotCommand::new(
                    "this_chat",
                    format!("Group title: {}", msg.chat.title().unwrap_or("no title")).to_string(),
                ),
            ])
            .scope(teloxide::types::BotCommandScope::Chat {
                chat_id: msg.chat.id.into(),
            })
            .send()
            .await?;
            log::info!("User asked for help");
            bot.send_message(msg.chat.id, Command::descriptions().to_string())
                .await?;
        }
        Command::EditTest => {
            log::info!("User asked for an edit test");
            let id = bot.send_message(msg.chat.id, "I will edit this")
                .await?.id;
            log::info!("Message sent with id: {id}");

            // Sleep for 5 seconds
            tokio::time::sleep(std::time::Duration::from_secs(5)).await;

            // Example action after sleep (optional)
            bot.edit_message_text(msg.chat.id, id, "Edited after 5 seconds")
                .await?;
        }
        Command::KeyboardTest => {
            log::info!("User asked for a keyboard test");
            bot.send_message(msg.chat.id, "This should have a keyboard")
                .reply_markup(make_keyboard())
                .await?;
            // https://docs.rs/teloxide/latest/src/buttons/buttons.rs.html#57
            // for a complete example
        }
        Command::Echo(text) => {
            log::info!("User asked to echo: {text}");
            bot.send_message(msg.chat.id, format!("You asked me to ech: {text}"))
                .await?;
        }
    }

    Ok(())
}
